{
  "name": "anything-backend",
  "version": "1.0.0",
  "description": "Backend with Apollo GraphQL and TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:docker": "tsc && cp -r src/schema dist/schema",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "npx ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:debug": "ts-node-dev --inspect --respawn --transpile-only src/index.ts",
    "dev:local": "npm run db:up && npm run dev",
    "dev:docker": "./dev.sh",
    "db:up": "docker compose up postgres -d",
    "db:down": "docker compose down postgres",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:status": "npx sequelize-cli db:migrate:status",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "setup": "ts-node src/scripts/setup.ts",
    "setup:postgres": "ts-node src/migrations/setup-postgres.ts",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.14.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.32.0",
    "@graphql-tools/merge": "^9.1.5",
    "@graphql-tools/schema": "^10.0.29",
    "@types/multer": "^1.4.7",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "apollo-server-express": "^3.12.0",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.1",
    "form-data": "^4.0.0",
    "graphql": "^16.6.0",
    "graphql-import-node": "^0.0.5",
    "helmet": "^7.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "openai": "^6.15.0",
    "pg": "^8.16.3",
    "sequelize": "^6.32.1",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/sequelize": "^4.28.20",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.6.1",
    "nodemon": "^3.0.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "graphql",
    "nodejs",
    "apollo",
    "typescript",
    "ai",
    "gemini"
  ],
  "author": "AnythingAI Team",
  "license": "ISC"
}
